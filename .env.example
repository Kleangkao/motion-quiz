# Motion Quiz — frontend (safe for browser bundle)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_SOLANA_CLUSTER=devnet
VITE_SOLANA_RPC_URL=https://api.devnet.solana.com
VITE_NFT_MINTING_ENABLED=true
VITE_APP_URL=

# Mainnet release (set on Vercel when ready — do not enable until Edge Function + RPC are configured):
# VITE_SOLANA_CLUSTER=mainnet-beta
# VITE_SOLANA_RPC_URL=https://your-mainnet-rpc.example
# Supabase Edge Function secret: MOTION_QUIZ_CLUSTER=mainnet-beta

# Service role key and Edge Function secrets are NOT listed here.
# See docs/supabase-leaderboard.md for server-side secret setup.
